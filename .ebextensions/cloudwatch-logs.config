# Ship this environment's application + instance logs to CloudWatch Logs
# (log group /aws/elasticbeanstalk/<env-name>/...), so the structured JSON
# lines written by services/logger.js — including the correlationId from
# middleware/requestId.js — are searchable there instead of only living on
# the instance's local disk. Works for both the Node.js and Docker EB
# platforms; EB already knows which files (stdout/stderr, eb-engine, nginx)
# to stream once this option is enabled.
#
# Requires the environment's instance profile to allow CloudWatch Logs
# writes (logs:CreateLogGroup/CreateLogStream/PutLogEvents) — the default
# "aws-elasticbeanstalk-ec2-role" managed by EB already includes this; a
# custom instance profile needs the AWSElasticBeanstalkWebTier (or
# CloudWatchAgentServerPolicy) permissions added.
option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 30
  aws:elasticbeanstalk:cloudwatch:logs:health:
    HealthStreamingEnabled: true
    DeleteOnTerminate: false
    RetentionInDays: 7
